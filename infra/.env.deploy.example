# Copy to infra/.env.deploy and fill in.
# Then: set -a && source infra/.env.deploy && set +a && ./infra/deploy_cloud_run.sh

# --- GCP project / region ---
PROJECT_ID=flightwatch-486618
REGION=us-central1
ARTIFACT_REPO=flightwatch
IMAGE_NAME=flightwatch-backend

# --- Cloud Run services ---
API_SERVICE=flightwatch-api
SCHEDULER_SERVICE=flightwatch-scheduler

# Runtime service account the Cloud Run services execute as.
# Needs: roles/datastore.user, roles/storage.objectViewer, roles/secretmanager.secretAccessor
SERVICE_ACCOUNT_EMAIL=flightwatch-runtime@flightwatch-486618.iam.gserviceaccount.com

# Service account Cloud Scheduler uses to invoke the scheduler service with OIDC.
# Needs: roles/run.invoker on the scheduler service (script grants this).
SCHEDULER_INVOKER_SA=flightwatch-scheduler-invoker@flightwatch-486618.iam.gserviceaccount.com

# --- Data sources ---
GCS_BUCKET=flight-batch-v1
GCS_FILE_PATH=flight_data_batch.csv
INGEST_RAW_BUCKET=flight-batch-v1
INGEST_RAW_PREFIX=raw
INGEST_MAX_OFFERS=20
INGEST_MAX_RETRIES=3

# --- App config ---
FROM_EMAIL=alerts@yourdomain.com
APP_BASE_URL=https://flightwatch-api-xxxx-uc.a.run.app

# --- Secret Manager secret NAMES (not values). Create secrets first, then reference by name here. ---
AMADEUS_CLIENT_ID_SECRET=amadeus-client-id
AMADEUS_CLIENT_SECRET_SECRET=amadeus-client-secret
SENDGRID_API_KEY_SECRET=sendgrid-api-key
SCHEDULER_TOKEN_SECRET=scheduler-token
ADMIN_TOKEN_SECRET=admin-token
SERPAPI_KEY_SECRET=serpapi-key

# --- Cron (optional overrides) ---
INGEST_CRON=*/15 * * * *
CHECK_PRICES_CRON=0 13 * * *
