# FlightWatch Backend Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost/flightwatch

# Amadeus API Credentials (from scripts/flight_fetch/)
# Get these from https://developers.amadeus.com/
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# Application Settings
APP_NAME=FlightWatch
DEBUG=True
API_V1_PREFIX=/api/v1